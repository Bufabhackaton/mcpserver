{
  "name": "bufab-mcp",
  "version": "1.0.0",
  "private": false,
  "type": "module",
  "description": "MCP server that exposes Bufab's design system (UI guidelines, tokens, section specs), infrastructure rules, and Azure Bicep validation. Includes a UI guideline validator usable via `bufab-mcp validate <file>`.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Bufabhackaton/mcpserver",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Bufabhackaton/mcpserver.git",
    "directory": "bufab-mcp"
  },
  "bugs": {
    "url": "https://github.com/Bufabhackaton/mcpserver/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "bufab",
    "design-system",
    "ui-guidelines",
    "azure",
    "bicep"
  ],
  "bin": {
    "bufab-mcp": "./bin/bufab-mcp.mjs"
  },
  "files": [
    "bin/",
    "dist/",
    "scripts/install-bicep.mjs",
    "scripts/validate.mjs",
    "scripts/seed-ui-rules.mjs",
    "agent-config/",
    ".lancedb/",
    ".lancedb-ui/",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "postinstall": "node scripts/install-bicep.mjs",
    "verify": "node scripts/mcp-smoke.mjs",
    "verify:ui": "node scripts/ui-seed-verify.mjs",
    "test:validator": "node scripts/validate-test.mjs",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@lancedb/lancedb": "^0.27.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "apache-arrow": "^18.1.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
