{
  "mcpServers": {
    "bufab-waf": {
      "command": "node",
      "args": ["/ABSOLUTE/PATH/TO/Guidlines/bufab-waf-mcp-proxy/dist/index.js"],
      "env": {
        "BUFAB_RULES_DB_PATH": "/ABSOLUTE/PATH/TO/your-rules.lancedb",
        "BUFAB_UI_DB_PATH": "/ABSOLUTE/PATH/TO/your-ui.lancedb",
        "BUFAB_UI_GUIDELINES_JSON": "/ABSOLUTE/PATH/TO/bufab/allguidelines/bufab_ui_guidelines.json",
        "BUFAB_UI_FORCE_RESEED": "0"
      }
    }
  }
}
